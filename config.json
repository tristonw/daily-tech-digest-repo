{
  "collector": {
    "hacker_news": {
      "enabled": true,
      "top_n": 30,
      "min_score": 50
    },
    "github_trending": {
      "enabled": true,
      "since": "daily",
      "top_n": 25
    },
    "rss": {
      "enabled": true,
      "feeds": [
        {"name": "Hacker News Frontpage", "url": "https://hnrss.org/frontpage"},
        {"name": "Ars Technica", "url": "https://feeds.arstechnica.com/arstechnica/index"},
        {"name": "The Verge", "url": "https://www.theverge.com/rss/index.xml"},
        {"name": "MIT Technology Review", "url": "https://www.technologyreview.com/feed/"}
      ],
      "per_feed_limit": 15
    },
    "http_timeout": 15,
    "watch_interval_seconds": 1800
  },
  "analyzer": {
    "window_hours": 24,
    "max_items_per_source": 15
  },
  "podcast": {
    "target_minutes": 15,
    "chars_per_minute": 280,
    "hosts": {
      "A": {"name": "晓宇", "role": "主持人", "voice": "zh-CN-YunxiNeural"},
      "B": {"name": "思琪", "role": "嘉宾", "voice": "zh-CN-XiaoxiaoNeural"}
    },
    "tts": {
      "provider": "piper",
      "ai_disclaimer": "本期节目的文稿与配音均由人工智能自动生成，内容仅供参考。",
      "piper": {
        "voices": {"A": "zh_CN-chaowen-medium", "B": "zh_CN-huayan-medium"},
        "model_dir": "data/piper_models",
        "bitrate": 64
      },
      "azure": {"region": "eastus", "output_format": "audio-24khz-48kbitrate-mono-mp3"}
    }
  },
  "content_filter": {
    "enabled": true,
    "block_keywords": [
      "trump", "biden", "election", "president", "senate", "congress",
      "white house", "immigration", "green card", "visa", "deport",
      "abortion", "gun", "shooting", "weapon", "missile", "war ", "military",
      "troop", "nato", "protest", "riot", "arrested", "sanction", "tariff",
      "espionage", "surveillance", "fbi", "cia", "nsa", "terror", "lawsuit",
      "政治", "选举", "总统", "战争", "军事", "武器", "抗议", "逮捕",
      "枪击", "移民", "制裁", "监控", "警方", "法院", "敏感"
    ]
  },
  "llm": {
    "model": "claude-opus-4-7",
    "max_tokens": 8192
  },
  "publish": {
    "site_base_url": "https://tristonw.github.io/daily-tech-digest-repo",
    "title": "每日科技播客",
    "author": "Daily Tech Digest",
    "email": "wangchenxiin1988@gmail.com",
    "description": "每天自动汇总 GitHub、Hacker News 与科技媒体的动态，生成双人对话播客。本节目的文稿与配音均由 AI 自动生成。",
    "category": "Technology",
    "language": "zh-cn",
    "explicit": false,
    "image": ""
  }
}
